{
  "openapi": "3.0.1",
  "info": { "title": "Sample3", "version": "1.0" },
  "paths": {
    "/orders": {
      "get": {
        "summary": "주문 목록",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Order" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "주문 생성",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateOrder" } }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Order" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "integer" }, "amount": { "type": "number" } }
      },
      "CreateOrder": {
        "type": "object",
        "properties": { "amount": { "type": "number" } }
      }
    }
  }
}
